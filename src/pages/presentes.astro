---
import Layout from '../layouts/Layout.astro';
import GiftCard from '../components/GiftCard.astro';
import { gifts, giftsCopy, formatDeliveryAddress } from '../data/gifts';
import { couple } from '../data/content';

const deliveryAddress = formatDeliveryAddress();
const delivery = giftsCopy.deliveryNote;
---

<Layout title={`Lista de Presentes — ${couple.displayOrder.join(' & ')}`}>
  <main class="gifts-page">
    <header class="gifts-page__header">
      <div class="container">
        <p class="eyebrow" data-reveal>Rychel &amp; Adria · 04.07.2026</p>
        <h1 class="gifts-page__heading script" data-reveal data-reveal-delay="100">{giftsCopy.heading}</h1>
        <div class="divider-ornament" data-reveal="fade" data-reveal-delay="200">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
            <path d="M12 2 L13 11 L22 12 L13 13 L12 22 L11 13 L2 12 L11 11 Z" fill="currentColor" opacity="0.8" />
          </svg>
        </div>
        <p class="gifts-page__intro" data-reveal data-reveal-delay="300">{giftsCopy.intro}</p>

        <aside class="gifts-page__delivery" data-reveal="scale" data-reveal-delay="400">
          <span class="gifts-page__delivery-label">{delivery.label}</span>

          <address class="gifts-page__delivery-address" data-delivery-address>
            <span class="gifts-page__delivery-row">
              <span class="gifts-page__delivery-key">Rua</span>
              <span class="gifts-page__delivery-value">{delivery.street}</span>
            </span>
            <span class="gifts-page__delivery-row">
              <span class="gifts-page__delivery-key">Nº</span>
              <span class="gifts-page__delivery-value">{delivery.number}</span>
            </span>
            <span class="gifts-page__delivery-row">
              <span class="gifts-page__delivery-key">CEP</span>
              <span class="gifts-page__delivery-value">{delivery.cep}</span>
            </span>
          </address>

          <div class="gifts-page__delivery-actions">
            <button
              type="button"
              class="gifts-page__delivery-cta gifts-page__delivery-cta--copy"
              data-copy-address={deliveryAddress}
              data-copy-label-default={delivery.copyCta}
              data-copy-label-done={delivery.copyCtaDone}
            >
              <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="4.5" y="4.5" width="9" height="9" rx="1.2" />
                <path d="M11.5 4.5 V3.2 a1 1 0 0 0 -1 -1 H3.2 a1 1 0 0 0 -1 1 v7.3 a1 1 0 0 0 1 1 H4.5" />
              </svg>
              <span data-copy-label>{delivery.copyCta}</span>
            </button>

            <a
              class="gifts-page__delivery-cta"
              href={delivery.mapUrl}
              target="_blank"
              rel="noopener"
            >
              {delivery.mapCta}
              <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M6 2 H14 V10" />
                <path d="M14 2 L6 10" />
                <path d="M11 9 V13 H3 V5 H7" />
              </svg>
            </a>
          </div>
        </aside>

        <p class="gifts-page__back">
          <a href="/">← Voltar para o convite</a>
        </p>
      </div>
    </header>

    <section class="gifts-page__list">
      <div class="container">
        <ul class="gifts-grid">
          {gifts.map((item, i) => (
            <li
              class="gifts-grid__item"
              data-reveal
              style={`transition-delay: ${Math.min(600, (i % 8) * 75)}ms`}
            >
              <GiftCard item={item} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  .gifts-page {
    background: var(--color-cream-soft);
    min-height: 100vh;
  }

  .gifts-page__header {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
  }

  .gifts-page__heading {
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--color-burgundy);
    line-height: 1;
    margin-block: 0.25rem;
  }

  .gifts-page__intro {
    max-width: 42rem;
    margin: 1.25rem auto 0;
    color: var(--color-ink-soft);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  .gifts-page__delivery {
    margin: 1.75rem auto 0;
    max-width: 32rem;
    padding: 1.1rem 1.4rem 1.25rem;
    background: var(--color-cream);
    border: 1px solid rgba(74, 15, 23, 0.18);
    border-radius: 12px;
    box-shadow: 0 6px 18px -14px rgba(74, 15, 23, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .gifts-page__delivery-label {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink);
    font-size: 0.98rem;
    letter-spacing: 0.02em;
  }
  .gifts-page__delivery-address {
    font-style: normal;
    display: grid;
    gap: 0.25rem;
    width: 100%;
    max-width: 22rem;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1rem;
    text-align: left;
  }
  .gifts-page__delivery-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding-block: 0.15rem;
    border-bottom: 1px solid rgba(74, 15, 23, 0.1);
  }
  .gifts-page__delivery-row:last-child { border-bottom: 0; }
  .gifts-page__delivery-key {
    font-family: var(--font-serif);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--color-ink-soft);
  }
  .gifts-page__delivery-value {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-ink);
    letter-spacing: 0.01em;
  }
  .gifts-page__delivery-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .gifts-page__delivery-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1.1rem;
    border: 1px solid var(--color-burgundy);
    border-radius: 999px;
    color: var(--color-burgundy);
    background: transparent;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .gifts-page__delivery-cta:hover {
    background: var(--color-burgundy);
    color: #fff;
    text-decoration: none;
  }
  .gifts-page__delivery-cta[data-copied='true'] {
    background: var(--color-forest);
    border-color: var(--color-forest);
    color: #fff;
  }

  .gifts-page__back {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
  }
  .gifts-page__back a {
    color: var(--color-ink-soft);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    text-decoration: none;
  }
  .gifts-page__back a:hover { color: var(--color-burgundy); }

  .gifts-page__list { padding-block: 0 clamp(3rem, 6vw, 5rem); }

  .gifts-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }
  .gifts-grid__item { display: block; }

  @media (min-width: 560px) {
    .gifts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .gifts-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1200px) {
    .gifts-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>

<script>
  function setupCopyDeliveryAddress() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-address]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copyAddress;
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
        }

        const label = btn.querySelector<HTMLElement>('[data-copy-label]');
        const done = btn.dataset.copyLabelDone;
        const def = btn.dataset.copyLabelDefault;
        btn.dataset.copied = 'true';
        if (label && done) label.textContent = done;
        window.setTimeout(() => {
          btn.dataset.copied = 'false';
          if (label && def) label.textContent = def;
        }, 1800);
      });
    });
  }

  setupCopyDeliveryAddress();
  document.addEventListener('astro:after-swap', setupCopyDeliveryAddress);
</script>
