---
import Layout from '../layouts/Layout.astro';
import GiftCard from '../components/GiftCard.astro';
import { gifts, giftsCopy } from '../data/gifts';
import { couple } from '../data/content';
---

<Layout title={`Lista de Presentes — ${couple.displayOrder.join(' & ')}`}>
  <main class="gifts-page">
    <header class="gifts-page__header">
      <div class="container">
        <p class="eyebrow">Rychel &amp; Adria · 04.07.2026</p>
        <h1 class="gifts-page__heading script">{giftsCopy.heading}</h1>
        <div class="divider-ornament">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
            <path d="M12 2 L13 11 L22 12 L13 13 L12 22 L11 13 L2 12 L11 11 Z" fill="currentColor" opacity="0.8" />
          </svg>
        </div>
        <p class="gifts-page__intro">{giftsCopy.intro}</p>
        <p class="gifts-page__back">
          <a href="/">← Voltar para o convite</a>
        </p>
      </div>
    </header>

    <section class="gifts-page__list">
      <div class="container">
        <ul class="gifts-grid">
          {gifts.map((item) => (
            <li class="gifts-grid__item">
              <GiftCard item={item} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  .gifts-page {
    background: var(--color-cream-soft);
    min-height: 100vh;
  }

  .gifts-page__header {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
  }

  .gifts-page__heading {
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--color-burgundy);
    line-height: 1;
    margin-block: 0.25rem;
  }

  .gifts-page__intro {
    max-width: 42rem;
    margin: 1.25rem auto 0;
    color: var(--color-ink-soft);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  .gifts-page__back {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
  }
  .gifts-page__back a {
    color: var(--color-ink-soft);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    text-decoration: none;
  }
  .gifts-page__back a:hover { color: var(--color-burgundy); }

  .gifts-page__list { padding-block: 0 clamp(3rem, 6vw, 5rem); }

  .gifts-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }
  .gifts-grid__item { display: block; }

  @media (min-width: 560px) {
    .gifts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .gifts-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1200px) {
    .gifts-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>

