---
interface Props {
  size?: number | string;
  initials?: string;
  class?: string;
}
const { size = 120, initials = 'AR', class: className = '' } = Astro.props;
---

<div class={`seal ${className}`} style={`--seal-size: ${typeof size === 'number' ? size + 'px' : size}`} aria-hidden="true">
  <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="seal__svg">
    <defs>
      <radialGradient id="sealGrad" cx="38%" cy="32%" r="65%">
        <stop offset="0%" stop-color="#f4d57e" />
        <stop offset="35%" stop-color="#d4a857" />
        <stop offset="78%" stop-color="#a37528" />
        <stop offset="100%" stop-color="#6e4d18" />
      </radialGradient>
      <radialGradient id="sealHighlight" cx="35%" cy="28%" r="20%">
        <stop offset="0%" stop-color="#fff5d4" stop-opacity="0.85" />
        <stop offset="100%" stop-color="#fff5d4" stop-opacity="0" />
      </radialGradient>
      <filter id="sealRoughness" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="3" />
        <feDisplacementMap in="SourceGraphic" scale="1.4" />
      </filter>
    </defs>

    <circle cx="50" cy="50" r="46" fill="url(#sealGrad)" filter="url(#sealRoughness)" />
    <circle cx="50" cy="50" r="42" fill="none" stroke="#6e4d18" stroke-width="0.6" opacity="0.5" />
    <circle cx="50" cy="50" r="40" fill="url(#sealHighlight)" />
    <path d="M 50 50 m -38 0 a 38 38 0 0 1 70 -10" stroke="#5a3e10" stroke-width="0.4" fill="none" opacity="0.3" />
  </svg>
  <span class="seal__letters">{initials}</span>
</div>

<style>
  .seal {
    position: relative;
    width: var(--seal-size);
    height: var(--seal-size);
    display: grid;
    place-items: center;
    filter: drop-shadow(0 5px 10px rgba(0, 0, 0, 0.35));
  }
  .seal__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .seal__letters {
    position: relative;
    font-family: var(--font-script);
    font-size: calc(var(--seal-size) * 0.5);
    color: #5a3e10;
    line-height: 1;
    text-shadow: 0 1px 0 rgba(255, 240, 200, 0.4);
    letter-spacing: -0.05em;
  }
</style>
