---
interface Props {
  size?: number | string;
  class?: string;
}
const { size = 160, class: className = '' } = Astro.props;
---

<svg
  viewBox="0 0 200 180"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height="auto"
  class={`lily ${className}`}
  aria-hidden="true"
>
  <defs>
    <radialGradient id="lilyPetal" cx="50%" cy="55%" r="65%">
      <stop offset="0%" stop-color="#fbe6e9" />
      <stop offset="35%" stop-color="#f0a5b3" />
      <stop offset="80%" stop-color="#cc4a64" />
      <stop offset="100%" stop-color="#922a44" />
    </radialGradient>
    <radialGradient id="lilyCenter" cx="50%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#fff4c2" />
      <stop offset="60%" stop-color="#f0b85a" />
      <stop offset="100%" stop-color="#a37528" />
    </radialGradient>
  </defs>

  <!-- Folhas laterais (atrás da flor) -->
  <g fill="#3d5a2e">
    <path d="M 38 110 Q 14 102 6 84 Q 8 70 24 80 Q 42 96 44 114 Z" />
    <path d="M 162 110 Q 186 102 194 84 Q 192 70 176 80 Q 158 96 156 114 Z" />
  </g>
  <g stroke="#1f3a1d" stroke-width="0.5" fill="none" opacity="0.5">
    <path d="M 42 110 Q 30 100 14 86" />
    <path d="M 158 110 Q 170 100 186 86" />
  </g>

  <!-- Flor centralizada -->
  <g transform="translate(100 90)">
    <g transform="rotate(0)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" />
    </g>
    <g transform="rotate(60)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" opacity="0.95" />
    </g>
    <g transform="rotate(120)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" opacity="0.95" />
    </g>
    <g transform="rotate(180)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" />
    </g>
    <g transform="rotate(240)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" opacity="0.95" />
    </g>
    <g transform="rotate(300)">
      <path d="M 0 0 Q -12 -22 -8 -55 Q 0 -68 8 -55 Q 12 -22 0 0 Z"
            fill="url(#lilyPetal)" stroke="#7a2034" stroke-width="0.6" opacity="0.95" />
    </g>

    <!-- Pintas estilo stargazer -->
    <g fill="#5e1d2a" opacity="0.55">
      <circle cx="2" cy="-22" r="1.1" />
      <circle cx="-3" cy="-32" r="0.9" />
      <circle cx="4" cy="-42" r="0.8" />
      <circle cx="-2" cy="-48" r="0.7" />
      <g transform="rotate(60)"><circle cx="2" cy="-26" r="1"/><circle cx="-2" cy="-36" r="0.8"/></g>
      <g transform="rotate(120)"><circle cx="2" cy="-26" r="1"/><circle cx="-2" cy="-36" r="0.8"/></g>
      <g transform="rotate(180)"><circle cx="2" cy="-26" r="1"/><circle cx="-2" cy="-36" r="0.8"/></g>
      <g transform="rotate(240)"><circle cx="2" cy="-26" r="1"/><circle cx="-2" cy="-36" r="0.8"/></g>
      <g transform="rotate(300)"><circle cx="2" cy="-26" r="1"/><circle cx="-2" cy="-36" r="0.8"/></g>
    </g>

    <!-- Miolo e estames -->
    <circle cx="0" cy="0" r="7" fill="url(#lilyCenter)" />
    <g stroke="#a37528" stroke-width="0.9" stroke-linecap="round" fill="none">
      <path d="M 0 0 L -5 -14" />
      <path d="M 0 0 L 5 -14" />
      <path d="M 0 0 L 0 -16" />
      <path d="M 0 0 L -3 -16" />
      <path d="M 0 0 L 3 -16" />
    </g>
    <g fill="#7a4f1a">
      <circle cx="-5" cy="-14" r="1.3" />
      <circle cx="5" cy="-14" r="1.3" />
      <circle cx="0" cy="-16" r="1.3" />
      <circle cx="-3" cy="-16" r="1.3" />
      <circle cx="3" cy="-16" r="1.3" />
    </g>
  </g>
</svg>

<style>
  .lily { display: block; }
</style>
