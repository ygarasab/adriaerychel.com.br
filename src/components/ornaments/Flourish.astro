---
interface Props {
  width?: number | string;
  color?: string;
  class?: string;
  flip?: boolean;
}
const { width = 120, color = '#b8893c', class: className = '', flip = false } = Astro.props;
---

<svg
  viewBox="0 0 240 28"
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height="auto"
  class={`flourish ${className}`}
  style={flip ? 'transform: scaleY(-1)' : ''}
  aria-hidden="true"
>
  <g fill="none" stroke={color} stroke-width="1.1" stroke-linecap="round">
    <path d="M 14 14 Q 60 4 110 12 Q 118 13 120 14" />
    <path d="M 226 14 Q 180 4 130 12 Q 122 13 120 14" />
    <path d="M 90 12 Q 96 4 102 6 Q 100 12 96 14" opacity="0.85" />
    <path d="M 150 12 Q 144 4 138 6 Q 140 12 144 14" opacity="0.85" />
    <circle cx="120" cy="14" r="1.6" fill={color} />
    <path d="M 113 14 L 127 14" stroke-width="0.6" opacity="0.6" />
    <circle cx="14" cy="14" r="1.2" fill={color} opacity="0.7" />
    <circle cx="226" cy="14" r="1.2" fill={color} opacity="0.7" />
  </g>
</svg>

<style>
  .flourish { display: block; }
</style>
