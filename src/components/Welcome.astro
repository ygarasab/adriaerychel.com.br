---
import { welcome } from '../data/content';
---

<section class="welcome" id="welcome">
  <div class="container">
    <h2 class="welcome__title script" data-reveal>{welcome.title}</h2>
    <div class="divider-ornament" data-reveal="fade" data-reveal-delay="100">
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
        <path d="M12 2 L13 11 L22 12 L13 13 L12 22 L11 13 L2 12 L11 11 Z" fill="currentColor" opacity="0.8" />
      </svg>
    </div>
    {welcome.body.map((p, i) => (
      <p
        class="welcome__paragraph"
        data-reveal
        style={`transition-delay: ${Math.min(600, 120 + i * 90)}ms`}
      >{p}</p>
    ))}
  </div>
</section>

<style>
  .welcome { background: var(--color-paper); }
  .welcome__title {
    text-align: center;
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    color: var(--color-burgundy);
    margin-bottom: 0.25rem;
  }
  .welcome__paragraph {
    font-size: 1.05rem;
    text-align: center;
    max-width: 38rem;
    margin: 0.5rem auto;
    color: var(--color-ink-soft);
  }
  .welcome__paragraph:first-of-type { margin-top: 1.25rem; }
</style>
