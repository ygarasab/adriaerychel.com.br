---
---

<dialog class="rsvp" id="rsvp-dialog" aria-labelledby="rsvp-title">
  <button class="rsvp__close" type="button" data-rsvp-close aria-label="Fechar">×</button>

  <div class="rsvp__thanks" id="rsvp-thanks" hidden role="status" aria-live="polite">
    <h2 class="rsvp__title script" id="rsvp-thanks-title">Obrigado!</h2>
    <p class="rsvp__thanks-body" id="rsvp-thanks-body"></p>
    <button class="rsvp__submit" type="button" data-rsvp-close>Fechar</button>
  </div>

  <form class="rsvp__form" id="rsvp-form" novalidate>
    <h2 class="rsvp__title script" id="rsvp-title">Confirme sua presença</h2>
    <p class="rsvp__hint">Pedimos que cada convidado preencha individualmente.</p>

    <div class="field field--name">
      <label class="field__label" for="rsvp-name">Seu nome</label>
      <input
        class="field__input"
        type="text"
        id="rsvp-name"
        name="name"
        autocomplete="off"
        autocapitalize="words"
        spellcheck="false"
        placeholder="Comece a digitar..."
        aria-autocomplete="list"
        aria-controls="rsvp-suggest"
        aria-expanded="false"
        required
      />
      <input type="hidden" name="guestId" id="rsvp-guest-id" />
      <ul class="rsvp__suggest" id="rsvp-suggest" role="listbox" hidden></ul>
      <p class="rsvp__name-help" id="rsvp-name-help" aria-live="polite"></p>
    </div>

    <fieldset class="field field--group">
      <legend class="field__label">Você poderá comparecer?</legend>
      <label class="radio">
        <input type="radio" name="attending" value="yes" required />
        <span>Sim, com alegria</span>
      </label>
      <label class="radio">
        <input type="radio" name="attending" value="no" />
        <span>Infelizmente não poderei</span>
      </label>
    </fieldset>

    <label class="field">
      <span class="field__label">Recado para os noivos (opcional)</span>
      <textarea class="field__input" name="message" rows="3"></textarea>
    </label>

    <button class="rsvp__submit" type="submit">Confirmar</button>

    <p class="rsvp__feedback" id="rsvp-feedback" role="status" aria-live="polite"></p>
  </form>
</dialog>

<style>
  .rsvp {
    border: 0;
    padding: 0;
    background: transparent;
    max-width: 32rem;
    width: 92vw;
    margin: auto;
  }

  .rsvp::backdrop {
    background: rgba(18, 35, 24, 0.7);
    backdrop-filter: blur(4px);
  }

  .rsvp__form,
  .rsvp__thanks {
    background: var(--color-paper);
    padding: 2rem 1.75rem;
    border-radius: 4px;
    border: 1px solid var(--color-gold);
    box-shadow: var(--shadow-soft);
    position: relative;
  }

  .rsvp__thanks {
    text-align: center;
    display: grid;
    gap: 1rem;
    place-items: center;
  }
  .rsvp__thanks[hidden] { display: none; }

  .rsvp__thanks .rsvp__title { margin-bottom: 0; }

  .rsvp__thanks-body {
    font-size: 1.1rem;
    color: var(--color-ink);
    line-height: 1.45;
    max-width: 26rem;
  }

  .rsvp__thanks .rsvp__submit { max-width: 16rem; }

  .rsvp__close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    font-size: 1.75rem;
    line-height: 1;
    color: var(--color-burgundy);
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
  }
  .rsvp__close:hover { color: var(--color-burgundy-dark); }

  .rsvp__title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    color: var(--color-burgundy);
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .rsvp__hint {
    text-align: center;
    color: var(--color-ink-soft);
    font-size: 1rem;
    margin-bottom: 1.25rem;
    font-style: italic;
  }

  .field { display: grid; gap: 0.4rem; margin-bottom: 1rem; }
  .field--name { position: relative; }

  .field__label {
    font-family: var(--font-serif);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.88rem;
    color: var(--color-burgundy);
  }

  .field__input {
    font: inherit;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid rgba(184, 137, 60, 0.5);
    border-radius: 3px;
    background: #fff;
    color: var(--color-ink);
  }
  .field__input:focus {
    outline: 2px solid var(--color-gold);
    outline-offset: 1px;
    border-color: var(--color-gold);
  }

  .field--group { border: 0; padding: 0; margin: 0 0 1rem; display: grid; gap: 0.5rem; }
  .radio { display: flex; gap: 0.55rem; align-items: center; font-size: 1.05rem; }

  .rsvp__suggest {
    position: absolute;
    top: calc(100% - 1.4em);
    left: 0;
    right: 0;
    margin-top: 0.25rem;
    list-style: none;
    padding: 0.25rem 0;
    background: #fff;
    border: 1px solid var(--color-gold);
    border-radius: 3px;
    box-shadow: 0 8px 20px -10px rgba(70, 25, 30, 0.25);
    max-height: 14rem;
    overflow-y: auto;
    z-index: 10;
  }
  .rsvp__suggest li {
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    font-size: 1.05rem;
    color: var(--color-ink);
  }
  .rsvp__suggest li[aria-selected="true"],
  .rsvp__suggest li:hover {
    background: rgba(184, 137, 60, 0.15);
    color: var(--color-burgundy);
  }

  .rsvp__name-help {
    font-size: 0.95rem;
    min-height: 1.1em;
    color: var(--color-ink-soft);
    font-style: italic;
  }
  .rsvp__name-help.is-ok { color: var(--color-forest); }
  .rsvp__name-help.is-err { color: var(--color-burgundy); }

  .rsvp__submit {
    width: 100%;
    margin-top: 0.5rem;
    padding: 1rem 1rem;
    background: var(--color-burgundy);
    color: var(--color-cream);
    font-family: var(--font-serif);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 1rem;
    border-radius: 3px;
    transition: background 0.2s ease;
  }
  .rsvp__submit:hover { background: var(--color-burgundy-dark); }
  .rsvp__submit:disabled { opacity: 0.6; cursor: progress; }

  .rsvp__feedback {
    margin-top: 1rem;
    text-align: center;
    font-size: 1.05rem;
    min-height: 1.4em;
  }
  .rsvp__feedback.is-ok { color: var(--color-forest); font-style: italic; }
  .rsvp__feedback.is-err { color: var(--color-burgundy); }
</style>

<script>
  import { searchGuests, normalizeName, guests } from '../data/guests';
  import type { Guest, GuestMatch } from '../data/guests';

  function displayName(guest: Guest): string {
    return guest.nickname ? `${guest.name} (${guest.nickname})` : guest.name;
  }

  function setupRsvp() {
    const dialog = document.getElementById('rsvp-dialog') as HTMLDialogElement | null;
    if (!dialog) return;

    const form = document.getElementById('rsvp-form') as HTMLFormElement | null;
    const feedback = document.getElementById('rsvp-feedback');
    const nameInput = document.getElementById('rsvp-name') as HTMLInputElement | null;
    const guestIdInput = document.getElementById('rsvp-guest-id') as HTMLInputElement | null;
    const suggestList = document.getElementById('rsvp-suggest') as HTMLUListElement | null;
    const nameHelp = document.getElementById('rsvp-name-help');
    const thanksPanel = document.getElementById('rsvp-thanks');
    const thanksTitle = document.getElementById('rsvp-thanks-title');
    const thanksBody = document.getElementById('rsvp-thanks-body');
    const triggers = document.querySelectorAll('[data-rsvp-trigger]');
    const closers = dialog.querySelectorAll('[data-rsvp-close]');

    if (!form || !nameInput || !guestIdInput || !suggestList) return;

    const showForm = () => {
      if (thanksPanel) thanksPanel.hidden = true;
      form.hidden = false;
      if (feedback) {
        feedback.textContent = '';
        feedback.className = 'rsvp__feedback';
      }
    };

    const showThanks = (
      guestName: string,
      attending: 'yes' | 'no',
      reconfirmed: boolean,
    ) => {
      if (!thanksPanel || !thanksTitle || !thanksBody) return;
      form.hidden = true;
      thanksPanel.hidden = false;

      const first = guestName.split(/\s+/)[0] || guestName;
      thanksTitle.textContent = reconfirmed ? 'Atualizado!' : 'Obrigado!';

      if (reconfirmed) {
        thanksBody.textContent =
          attending === 'yes'
            ? `Atualizamos sua resposta, ${first}. Sua presença está confirmada — até 04 de julho!`
            : `Atualizamos sua resposta, ${first}. Vamos sentir sua falta.`;
      } else {
        thanksBody.textContent =
          attending === 'yes'
            ? `Estamos ansiosos para celebrar com você, ${first}. Até 04 de julho!`
            : `Vamos sentir sua falta, ${first}. Obrigado por avisar.`;
      }
    };

    let currentMatches: GuestMatch[] = [];
    let activeIdx = -1;

    const setNameStatus = (text: string, kind: '' | 'ok' | 'err' = '') => {
      if (!nameHelp) return;
      nameHelp.textContent = text;
      nameHelp.className = `rsvp__name-help${kind ? ` is-${kind}` : ''}`;
    };

    const clearSuggest = () => {
      currentMatches = [];
      activeIdx = -1;
      suggestList.innerHTML = '';
      suggestList.hidden = true;
      nameInput.setAttribute('aria-expanded', 'false');
    };

    const renderSuggest = (matches: GuestMatch[]) => {
      currentMatches = matches;
      activeIdx = matches.length > 0 ? 0 : -1;
      if (matches.length === 0) {
        clearSuggest();
        return;
      }
      suggestList.innerHTML = matches
        .map(
          (m, i) =>
            `<li role="option" id="rsvp-opt-${i}" data-idx="${i}" aria-selected="${i === activeIdx ? 'true' : 'false'}">${displayName(m)}</li>`,
        )
        .join('');
      suggestList.hidden = false;
      nameInput.setAttribute('aria-expanded', 'true');
    };

    const updateActive = (next: number) => {
      const items = suggestList.querySelectorAll('li');
      if (items.length === 0) return;
      activeIdx = ((next % items.length) + items.length) % items.length;
      items.forEach((li, i) => li.setAttribute('aria-selected', i === activeIdx ? 'true' : 'false'));
      const active = items[activeIdx] as HTMLElement;
      active.scrollIntoView({ block: 'nearest' });
    };

    const selectMatch = (match: GuestMatch | Guest) => {
      nameInput.value = displayName(match);
      guestIdInput.value = match.id;
      setNameStatus(`Identificado como ${match.name}.`, 'ok');
      clearSuggest();
    };

    nameInput.addEventListener('input', () => {
      guestIdInput.value = '';
      setNameStatus('');
      renderSuggest(searchGuests(nameInput.value));
    });

    nameInput.addEventListener('focus', () => {
      if (nameInput.value.trim().length >= 2 && !guestIdInput.value) {
        renderSuggest(searchGuests(nameInput.value));
      }
    });

    nameInput.addEventListener('keydown', (e) => {
      if (suggestList.hidden || currentMatches.length === 0) {
        if (e.key === 'ArrowDown' && nameInput.value.length >= 2) {
          renderSuggest(searchGuests(nameInput.value));
        }
        return;
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        updateActive(activeIdx + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        updateActive(activeIdx - 1);
      } else if (e.key === 'Enter') {
        if (activeIdx >= 0) {
          e.preventDefault();
          selectMatch(currentMatches[activeIdx]);
        }
      } else if (e.key === 'Escape') {
        clearSuggest();
      }
    });

    suggestList.addEventListener('mousedown', (e) => {
      const li = (e.target as HTMLElement).closest('li[data-idx]') as HTMLElement | null;
      if (!li) return;
      e.preventDefault();
      const idx = Number(li.dataset.idx);
      if (currentMatches[idx]) selectMatch(currentMatches[idx]);
    });

    document.addEventListener('click', (e) => {
      if (!suggestList.contains(e.target as Node) && e.target !== nameInput) {
        clearSuggest();
      }
    });

    triggers.forEach((t) =>
      t.addEventListener('click', (e) => {
        e.preventDefault();
        showForm();
        dialog.showModal();
        window.setTimeout(() => nameInput.focus(), 50);
      }),
    );

    closers.forEach((c) => c.addEventListener('click', () => dialog.close()));

    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      const inside =
        e.clientX >= rect.left &&
        e.clientX <= rect.right &&
        e.clientY >= rect.top &&
        e.clientY <= rect.bottom;
      if (!inside) dialog.close();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Se ainda não há guestId mas o usuário digitou algo, tenta auto-match
      // exato (nome inteiro escrito sem clicar na sugestão).
      if (!guestIdInput.value && nameInput.value.trim().length >= 2) {
        const typed = normalizeName(nameInput.value);
        const exact = guests.find((g) => {
          const n = normalizeName(g.name);
          const full = g.nickname ? `${n} ${normalizeName(g.nickname)}` : n;
          return n === typed || full === typed;
        });
        if (exact) selectMatch(exact);
      }

      if (!guestIdInput.value) {
        setNameStatus('Não encontramos esse nome na lista. Selecione uma sugestão.', 'err');
        nameInput.focus();
        return;
      }

      if (!form.reportValidity()) return;

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      if (feedback) {
        feedback.textContent = 'Enviando...';
        feedback.className = 'rsvp__feedback';
      }

      const fd = new FormData(form);
      const data = {
        guestId: String(fd.get('guestId') || ''),
        attending: String(fd.get('attending') || ''),
        message: String(fd.get('message') || ''),
      };
      const isDev = import.meta.env.DEV;

      try {
        const res = await fetch('/api/rsvp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const payload = (await res.json().catch(() => ({}))) as {
          guest?: { name?: string };
          reconfirmed?: boolean;
        };
        const guestName = payload?.guest?.name || 'você';
        const reconfirmed = Boolean(payload?.reconfirmed);
        form.reset();
        guestIdInput.value = '';
        setNameStatus('');
        showThanks(guestName, data.attending as 'yes' | 'no', reconfirmed);
      } catch (err) {
        console.error('[rsvp]', err);
        if (isDev) {
          console.info('[rsvp] modo dev — payload simulado:', data);
          form.reset();
          guestIdInput.value = '';
          setNameStatus('');
          showThanks('você', data.attending as 'yes' | 'no', false);
        } else if (feedback) {
          feedback.textContent =
            'Não conseguimos registrar agora. Tente novamente em instantes ou avise os noivos.';
          feedback.className = 'rsvp__feedback is-err';
        }
      } finally {
        submitBtn.disabled = false;
      }
    });
  }

  setupRsvp();
  document.addEventListener('astro:after-swap', setupRsvp);
</script>
