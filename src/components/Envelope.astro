---
import { Image } from 'astro:assets';
import DriedSpray from './ornaments/DriedSpray.astro';
import logo from '../assets/logo-ar.png';
---

<div class="envelope-stage" id="envelope-stage" aria-hidden="false">
  <div class="envelope-decor envelope-decor--top">
    <DriedSpray size="100%" withRose={true} />
  </div>

  <button class="envelope" id="envelope-button" type="button" aria-label="Clique para abrir o convite">
    <div class="envelope__paper"></div>
    <div class="envelope__body" aria-hidden="true"></div>
    <div class="envelope__flap" aria-hidden="true">
      <div class="envelope__flap-shadow"></div>
    </div>
    <div class="envelope__seal-wrap">
      <Image src={logo} alt="" class="envelope__logo" widths={[120, 200, 280]} sizes="140px" />
    </div>
  </button>

  <div class="envelope-decor envelope-decor--bottom">
    <DriedSpray size="100%" withRose={false} flip={true} />
  </div>

  <p class="envelope-cta" id="envelope-cta">Clique para abrir</p>
</div>

<style>
  .envelope-stage {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    place-items: center;
    background:
      radial-gradient(ellipse at center, #faf6ec 0%, #ede3cf 100%);
    transition: opacity 0.8s ease, visibility 0.8s ease;
    overflow: hidden;
  }

  /* Sutil grão de papel */
  .envelope-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(157, 139, 102, 0.05) 0%, transparent 30%),
      radial-gradient(circle at 80% 70%, rgba(157, 139, 102, 0.06) 0%, transparent 35%);
    pointer-events: none;
  }

  .envelope-stage.is-open {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .envelope-decor {
    position: absolute;
    width: clamp(180px, 26vw, 320px);
    aspect-ratio: 220 / 260;
    pointer-events: none;
    z-index: 1;
  }
  .envelope-decor--top {
    top: 2%;
    left: 1%;
  }
  .envelope-decor--bottom {
    bottom: 2%;
    right: 1%;
    transform: rotate(180deg);
  }

  .envelope {
    --w: clamp(280px, 56vw, 440px);
    width: var(--w);
    aspect-ratio: 1.42 / 1;
    position: relative;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 0;
    z-index: 2;
    transition: transform 0.5s ease;
    filter:
      drop-shadow(0 30px 40px rgba(74, 15, 23, 0.28))
      drop-shadow(0 8px 12px rgba(74, 15, 23, 0.15));
  }

  .envelope:hover { transform: translateY(-4px) scale(1.015); }
  .envelope:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 12px; border-radius: 4px; }

  /* Sombra do envelope no chão */
  .envelope__paper {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(165deg, #7a1d27 0%, #5e151d 100%);
    border-radius: 3px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.06),
      inset 0 -2px 8px rgba(0, 0, 0, 0.18);
  }

  /* Corpo: parte de baixo do envelope */
  .envelope__body {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, #5e151d 0%, #4a0f17 100%);
    clip-path: polygon(0 50%, 100% 50%, 100% 100%, 0 100%);
    border-radius: 3px;
    box-shadow:
      inset 0 4px 8px rgba(0, 0, 0, 0.25);
  }
  /* Linha sutil indicando a aba que fecha por baixo (lateral esquerda e direita do triângulo) */
  .envelope__body::before,
  .envelope__body::after {
    content: '';
    position: absolute;
    top: 0;
    width: 1px;
    height: 100%;
    background: rgba(0, 0, 0, 0.15);
  }
  .envelope__body::before { left: 50%; transform: skewX(-44deg); transform-origin: top; }
  .envelope__body::after  { left: 50%; transform: skewX(44deg);  transform-origin: top; }

  /* Aba superior fechada */
  .envelope__flap {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(170deg, #82202b 0%, #5a1620 100%);
    clip-path: polygon(0 0, 100% 0, 50% 62%);
    transform-origin: top center;
    transition: transform 0.95s cubic-bezier(0.55, 0.05, 0.4, 1);
    border-radius: 3px 3px 0 0;
  }
  .envelope__flap-shadow {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.25) 100%);
    clip-path: polygon(0 0, 100% 0, 50% 62%);
  }

  .envelope.is-opening .envelope__flap {
    transform: rotateX(178deg);
  }

  .envelope__seal-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    transition: transform 0.6s ease, opacity 0.6s ease;
    width: clamp(110px, 24%, 160px);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    background: radial-gradient(ellipse at 35% 30%, #faf6ec 0%, #ede3cf 80%);
    border-radius: 50%;
    box-shadow:
      0 6px 14px rgba(74, 15, 23, 0.35),
      inset 0 0 0 1px rgba(184, 137, 60, 0.4),
      inset 0 -2px 6px rgba(0, 0, 0, 0.08);
  }
  .envelope__logo {
    width: 72%;
    height: auto;
    display: block;
  }

  .envelope.is-opening .envelope__seal-wrap {
    transform: translate(-50%, -50%) scale(0.92) rotate(18deg);
    opacity: 0.5;
  }

  .envelope-cta {
    position: absolute;
    bottom: 14%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-burgundy);
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    animation: pulse 2.4s ease-in-out infinite;
    z-index: 2;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.75; }
    50% { opacity: 1; }
  }

  @media (max-width: 560px) {
    .envelope-decor { width: clamp(140px, 38vw, 200px); opacity: 0.9; }
    .envelope-decor--top { top: 1%; left: -2%; }
    .envelope-decor--bottom { bottom: 1%; right: -2%; }
    .envelope-cta { bottom: 18%; font-size: 1.05rem; }
  }
</style>

<script>
  function setupEnvelope() {
    const stage = document.getElementById('envelope-stage');
    const button = document.getElementById('envelope-button');
    if (!stage || !button) return;

    if (sessionStorage.getItem('envelope-opened') === 'true') {
      stage.classList.add('is-open');
      return;
    }

    button.addEventListener('click', () => {
      button.classList.add('is-opening');
      window.setTimeout(() => {
        stage.classList.add('is-open');
        sessionStorage.setItem('envelope-opened', 'true');
      }, 950);
    });
  }

  setupEnvelope();
  document.addEventListener('astro:after-swap', setupEnvelope);
</script>
