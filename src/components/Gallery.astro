---
import { Image } from 'astro:assets';
import g1 from '../assets/photos/IMG_2877.webp';
import g2 from '../assets/photos/IMG_2667.webp';
import g3 from '../assets/photos/IMG_novafoto3.webp';
---

<section class="gallery" aria-label="Galeria">
  <div class="gallery__grid">
    <figure class="gallery__item gallery__item--tall">
      <Image src={g1} alt="Adria e Rychel em close-up" widths={[400, 700, 1000]} sizes="(min-width: 800px) 33vw, 100vw" />
    </figure>
    <figure class="gallery__item">
      <Image src={g2} alt="Adria e Rychel se abraçando" widths={[400, 700, 1000]} sizes="(min-width: 800px) 33vw, 100vw" />
    </figure>
    <figure class="gallery__item gallery__item--tall">
      <Image src={g3} alt="Adria e Rychel de costas contemplando o rio" widths={[400, 700, 1000]} sizes="(min-width: 800px) 33vw, 100vw" />
    </figure>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-paper);
    padding-block: 0;
  }

  .gallery__grid {
    display: grid;
    gap: 0;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .gallery__item {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: relative;
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.12);
    filter: brightness(0.82) saturate(0.85);
    transition:
      transform 1.4s cubic-bezier(0.2, 0.6, 0.2, 1),
      filter 1.4s ease;
    will-change: transform, filter;
  }
  .gallery__item.is-visible img {
    transform: scale(1);
    filter: brightness(1) saturate(1);
  }
  .gallery__item:hover img {
    transform: scale(1.04);
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery__item img {
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  function setupGallery() {
    const items = document.querySelectorAll<HTMLElement>('.gallery__item');
    if (!items.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || !('IntersectionObserver' in window)) {
      items.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -40px 0px' }
    );

    items.forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.85 && rect.bottom > 0) {
        el.classList.add('is-visible');
      } else {
        io.observe(el);
      }
    });
  }

  setupGallery();
  document.addEventListener('astro:after-swap', setupGallery);
</script>
