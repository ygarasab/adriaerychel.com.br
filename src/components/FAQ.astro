---
import { Image } from 'astro:assets';
import { faq } from '../data/faq';
import tower from '../assets/champagne-tower.avif';
---

<section class="faq">
  <div class="container faq__inner">
    <aside class="faq__intro">
      <h2 class="faq__title">
        <span class="faq__title-line">Dúvidas</span>
        <span class="faq__title-line">Frequentes</span>
      </h2>
      <div class="faq__art" aria-hidden="true">
        <Image src={tower} alt="" widths={[200, 280, 360]} sizes="(max-width: 880px) 50vw, 280px" />
      </div>
    </aside>

    <ol class="faq__list">
      {faq.map((item, idx) => (
        <li class="faq__item">
          <span class="faq__index">{String(idx + 1).padStart(2, '0')}</span>
          <h3 class="faq__question">{item.question}</h3>
          <p class="faq__answer">{item.answer}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .faq {
    background: var(--color-paper);
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .faq__inner {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
    grid-template-columns: 1fr;
  }

  .faq__intro {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-content: start;
  }

  .faq__title {
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-forest);
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: 0.02em;
    display: grid;
    gap: 0.05em;
  }
  .faq__title-line {
    display: block;
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  }

  .faq__art {
    max-width: clamp(220px, 26vw, 320px);
  }
  .faq__art :global(img) {
    width: 100%;
    height: auto;
  }

  .faq__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.25rem);
  }

  .faq__item {
    display: grid;
    gap: 0.85rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(42, 33, 24, 0.45);
  }

  .faq__index {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-ink);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .faq__question {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    color: var(--color-ink);
    line-height: 1.3;
  }

  .faq__answer {
    color: var(--color-ink-soft);
    font-size: 1.08rem;
    line-height: 1.6;
    max-width: 38rem;
  }

  @media (min-width: 880px) {
    .faq__inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      column-gap: clamp(2.5rem, 6vw, 5rem);
      align-items: start;
    }
  }
</style>
