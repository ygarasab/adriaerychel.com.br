{
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    {
      "route": "/api/rsvp",
      "methods": ["POST"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/_astro/*", "/api/*", "*.{png,jpg,jpeg,gif,svg,webp,avif,ico,css,js,woff,woff2}"]
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=0, must-revalidate",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".webp": "image/webp",
    ".avif": "image/avif"
  }
}
